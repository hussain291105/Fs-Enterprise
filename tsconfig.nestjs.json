{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/main.ts",
    "src/app.module.ts",
    "src/app.controller.ts",
    "src/database/**/*",
    "src/billing/**/*",
    "src/stock/**/*",
    "src/expenses/**/*",
    "src/reports/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.tsx",
    "src/**/*.jsx",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.d.ts",
    "src/components/**/*",
    "src/pages/**/*",
    "src/hooks/**/*",
    "src/lib/**/*",
    "src/assets/**/*",
    "src/integrations/**/*",
    "src/types/**/*",
    "src/api/**/*",
    "src/*.css",
    "src/*.html",
    "src/main.tsx",
    "src/App.tsx"
  ]
}
